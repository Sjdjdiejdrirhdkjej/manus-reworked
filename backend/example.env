
# Mistral AI Configuration
MISTRAL_API_KEY=your_mistral_api_key_here

# Instructions:
# 1. Copy this file to .env
# 2. Replace 'your_mistral_api_key_here' with your actual Mistral API key
# 3. Get your API key from https://console.mistral.ai/
# 4. The .env file will be ignored by git for security

# Example:
# MISTRAL_API_KEY=sk-1234567890abcdef1234567890abcdef
